<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
   <center>
      <SplitPane dividerPositions="0.5" prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
         <items>
            <VBox prefHeight="398.0" prefWidth="248.0">
               <children>
                  <Label prefHeight="18.0" prefWidth="339.0" text="Movie name" textAlignment="CENTER" VBox.vgrow="ALWAYS" />
                  <TextField fx:id="movieName" />
                  <Label text="Username" />
                  <TextField fx:id="username" />
                  <Label text="Rating" />
                  <HBox prefHeight="33.0" prefWidth="321.0">
                     <children>
                        <Button contentDisplay="CENTER" mnemonicParsing="false" text="1" />
                        <Button contentDisplay="CENTER" mnemonicParsing="false" text="2" />
                        <Button contentDisplay="CENTER" mnemonicParsing="false" text="3" />
                        <Button contentDisplay="CENTER" mnemonicParsing="false" text="4" />
                        <Button contentDisplay="CENTER" mnemonicParsing="false" text="5" />
                        <Button contentDisplay="CENTER" mnemonicParsing="false" text="6" />
                     </children>
                  </HBox>
                  <Label text="Review" />
                  <TextArea fx:id="review" prefHeight="211.0" prefWidth="307.0" />
                  <Button contentDisplay="RIGHT" mnemonicParsing="false" onAction="#handleAddReview" prefHeight="31.0" prefWidth="323.0" text="Add review" textAlignment="RIGHT" />
               </children>
            </VBox>
            <ListView prefHeight="398.0" prefWidth="335.0" />
         </items>
      </SplitPane>
   </center>

    <fx:define>
        <ToggleGroup fx:id="ratingGroup" />
    </fx:define>

</BorderPane>
